# These environment vars are shared across all services.

# User/pass/db for the postgresql db.  Used by db and web services.
DB_PASSWORD={{ inventory_user_password }}
DB_USER={{ postgresql_databases[0]['owner'] }}
DB_NAME={{ postgresql_databases[0]['name'] }}
DB_HOST={{ hostvars[groups['has_postgres'][0]]['ansible_host'] }}
DB_PORT=5432

DJANGO_SECRET_KEY="{{ django_secret_key }}"

# Initial values used by runscript create_super_user only on first code deploy.
INITIAL_ADMIN_USER={{ django_admin_user }}
INITIAL_ADMIN_EMAIL={{ django_admin_email }}
INITIAL_ADMIN_PASSWORD={{ django_admin_pass }}
