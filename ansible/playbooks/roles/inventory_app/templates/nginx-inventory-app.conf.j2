# nginx.conf
upstream inventory_app {
    # connect to this socket
    server unix://{{ inventory_app_uwsgi_socket_file }};    # for a file socket
    #server 127.0.0.1:8000;      # for a web port socket
}

# redirect all
server {
    # the port your site will be served on
    listen      80;
    #listen [::]:80;
    # the domain name it will serve for
    server_name {{ inventory_app_nginx_fqdn }};   # substitute your machine's IP address or FQDN
    {% if inventory_app_django_configuration == 'Production' %}
    return 301 https://$host$request_uri;
    {% else %}
    charset     utf-8;

    #Max upload size
    client_max_body_size 75M;   # adjust to taste

    location /robots.txt {
        alias {{ inventory_app_static_mount_root }}/robots.txt;
    }

    location /static {
        alias {{ inventory_app_static_mount_root }};     # your Django project's static files
    }

    # Finally, send all non-media requests to the Django server.
    location / {
        uwsgi_pass  inventory_app;
        include     /etc/nginx/uwsgi_params; # or the uwsgi_params you installed manually
        uwsgi_read_timeout 300;
    }
    {% endif %}
}

